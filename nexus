#!/usr/bin/env bash
# nexus — OpenClaw CLI for Sentinel Nexus
# Low-token interface for updating all platform state.
#
# Usage:
#   ./nexus status
#   ./nexus task start  <id> [summary]
#   ./nexus task done   <id>
#   ./nexus task block  <id> <reason>
#   ./nexus task wait   <id> <waitingFor>
#   ./nexus task approve <id>
#   ./nexus task list
#   ./nexus task inspect <id>
#   ./nexus task new    <title> <owner> <lane> [due:YYYY-MM-DD] [needsApproval:true|false]
#   ./nexus project status   <id> <active|watch|blocked|parked|done>
#   ./nexus project progress <id> <0-100>
#   ./nexus agent  <id> <active|limited-visibility|offline> [focus]
#   ./nexus calendar add <title> <type:task|meeting|deadline|routine> <YYYY-MM-DD> <owner> [detail]
#   ./nexus memory add <title> <summary> [tags:comma,separated]
#   ./nexus log <title> [detail]
#
# Environment:
#   NEXUS_API  — base URL (default: http://localhost:3001)

set -euo pipefail

BASE="${NEXUS_API:-http://localhost:3001}"

_curl() {
  curl -sf --max-time 10 "$@"
}

_patch() {
  _curl -X PATCH "$BASE$1" -H "Content-Type: application/json" -d "$2"
}

_post() {
  _curl -X POST "$BASE$1" -H "Content-Type: application/json" -d "$2"
}

_jq_compact() {
  if command -v jq &>/dev/null; then
    jq "$@"
  else
    cat
  fi
}

_python_json_filter() {
  python3 - "$@"
}

_json_field() {
  local field="$1"
  python3 - "$field" <<'PY'
import json, sys
field = sys.argv[1]
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(1)
value = data.get(field)
if value is None:
    sys.exit(1)
print(value)
PY
}

_task_lookup_by_title() {
  local title="$1"
  _curl "$BASE/api/tasks" | python3 - "$title" <<'PY'
import json, sys
title = sys.argv[1]
items = json.load(sys.stdin)
matches = [t for t in items if t.get('title') == title]
if not matches:
    print('{}')
else:
    print(json.dumps(matches[-1]))
PY
}

cmd="${1:-}"
shift || true

case "$cmd" in

  status)
    _curl "$BASE/api/bootstrap" | _jq_compact '{
      mission_pct: .missionCommand.mission.progressPercent,
      tasks_total: (.tasks | length),
      blocked: ([.tasks[] | select(.status == "Blocked")] | length),
      active: ([.tasks[] | select(.status == "In Progress")] | length),
      done: ([.tasks[] | select(.status == "Done")] | length),
      queued: ([.tasks[] | select(.status == "Queued")] | length),
      projects: (.missionCommand.projects | length),
      calendar_items: (.missionCommand.calendar | length),
      memories: (.missionCommand.memories | length),
      last_activity: (.activity[0].title // "none")
    }'
    ;;

  task)
    subcmd="${1:-}"; shift || true
    case "$subcmd" in
      start)
        id="${1:?task id required}"; shift
        summary="${1:-}"; shift || true
        _patch "/api/tasks/$id" "{\"status\":\"In Progress\",\"summary\":\"$summary\"}" \
          | _jq_compact '{id, status, title, summary, blockedReason, waitingFor, needsApproval, readyToReport}'
        ;;
      done)
        id="${1:?task id required}"
        _patch "/api/tasks/$id" '{"status":"Done","readyToReport":true}' \
          | _jq_compact '{id, status, title, completedAt, readyToReport}'
        ;;
      block)
        id="${1:?task id required}"; shift
        reason="${1:?block reason required}"
        _patch "/api/tasks/$id" "{\"status\":\"Blocked\",\"blockedReason\":\"$reason\"}" \
          | _jq_compact '{id, status, title, blockedReason, readyToReport}'
        ;;
      wait)
        id="${1:?task id required}"; shift
        waiting="${1:?waitingFor required}"
        _patch "/api/tasks/$id" "{\"needsUserInput\":true,\"waitingFor\":\"$waiting\"}" \
          | _jq_compact '{id, status, title, waitingFor, needsUserInput}'
        ;;
      approve)
        id="${1:?task id required}"
        _post "/api/tasks/$id/approve" '{}' \
          | _jq_compact '{id, status, title, needsApproval, readyToReport}'
        ;;
      list)
        _curl "$BASE/api/tasks" \
          | _jq_compact 'map({id, title, status, owner, needsApproval, needsUserInput, readyToReport, blockedReason, waitingFor})'
        ;;
      inspect)
        id="${1:?task id required}"
        if command -v jq &>/dev/null; then
          _curl "$BASE/api/tasks" | jq --arg id "$id" 'map(select(.id == $id)) | .[0]'
        else
          TASKS_JSON="$(_curl "$BASE/api/tasks")"
          TASKS_JSON="$TASKS_JSON" _python_json_filter "$id" <<'PY'
import json
import os
import sys

task_id = sys.argv[1]
data = json.loads(os.environ.get('TASKS_JSON', '[]'))
match = next((t for t in data if t.get('id') == task_id), None)
if match is None:
    print('{}')
else:
    print(json.dumps(match, indent=2))
PY
        fi
        ;;
      new)
        title="${1:?title required}"; shift
        owner="${1:?owner required}"; shift
        lane="${1:?lane required}"; shift
        due="${1:-$(date -d '+7 days' +%Y-%m-%d 2>/dev/null || date -v+7d +%Y-%m-%d)}"
        shift || true
        needs_approval_raw="${1:-false}"
        if [ "$needs_approval_raw" = "true" ]; then
          needs_approval=true
        else
          needs_approval=false
        fi
        _post "/api/tasks" "{\"title\":\"$title\",\"owner\":\"$owner\",\"lane\":\"$lane\",\"due\":\"$due\",\"needsApproval\":$needs_approval}" \
          | _jq_compact '{id, status, title, owner, lane, due, needsApproval, needsUserInput, readyToReport}'
        ;;
      *)
        echo "Usage: nexus task <start|done|block|wait|approve|list|inspect|new> ..." >&2
        exit 1
        ;;
    esac
    ;;

  project)
    subcmd="${1:-}"; shift || true
    case "$subcmd" in
      status)
        id="${1:?project id required}"; shift
        status="${1:?status required}"
        _patch "/api/projects/$id" "{\"status\":\"$status\"}" \
          | _jq_compact '{id, name, status, progressPercent}'
        ;;
      progress)
        id="${1:?project id required}"; shift
        pct="${1:?progress 0-100 required}"
        _patch "/api/projects/$id" "{\"progressPercent\":$pct}" \
          | _jq_compact '{id, name, progressPercent}'
        ;;
      *)
        echo "Usage: nexus project <status|progress> ..." >&2
        exit 1
        ;;
    esac
    ;;

  agent)
    id="${1:?team member id required}"; shift
    status="${1:?status required}"; shift
    focus="${1:-}"; shift || true
    _patch "/api/team/$id" "{\"status\":\"$status\",\"focus\":\"$focus\"}" \
      | _jq_compact '{id, name, status, focus}'
    ;;

  calendar)
    subcmd="${1:-}"; shift || true
    case "$subcmd" in
      add)
        title="${1:?title required}"; shift
        type="${1:?type required}"; shift
        starts="${1:?date YYYY-MM-DD required}"; shift
        owner="${1:?owner required}"; shift
        detail="${1:-}"; shift || true
        _post "/api/calendar" "{\"title\":\"$title\",\"type\":\"$type\",\"startsAt\":\"${starts}T00:00:00.000Z\",\"owner\":\"$owner\",\"detail\":\"$detail\"}" \
          | _jq_compact '{id, title, type, startsAt, owner}'
        ;;
      *)
        echo "Usage: nexus calendar add <title> <type> <YYYY-MM-DD> <owner> [detail]" >&2
        exit 1
        ;;
    esac
    ;;

  memory)
    subcmd="${1:-}"; shift || true
    case "$subcmd" in
      add)
        title="${1:?title required}"; shift
        summary="${1:?summary required}"; shift
        raw_tags="${1:-}"; shift || true
        if [ -n "$raw_tags" ] && command -v jq &>/dev/null; then
          tags=$(echo "$raw_tags" | jq -R 'split(",")')
        else
          tags="[]"
        fi
        _post "/api/memories" "{\"title\":\"$title\",\"summary\":\"$summary\",\"tags\":$tags}" \
          | _jq_compact '{id, title, kind, tags}'
        ;;
      *)
        echo "Usage: nexus memory add <title> <summary> [tag1,tag2]" >&2
        exit 1
        ;;
    esac
    ;;

  log)
    title="${1:?log title required}"; shift
    detail="${1:-}"; shift || true
    _post "/api/activity" "{\"title\":\"$title\",\"detail\":\"$detail\",\"type\":\"status\"}" \
      | _jq_compact '{id, title, detail, timestamp}'
    ;;

  *)
    cat <<'EOF'
nexus — Sentinel Nexus CLI

Commands:
  status                                    system snapshot (tasks, blocked, mission%)
  task start   <id> [summary]                            mark task In Progress
  task done    <id>                                      mark task Done + ready to report
  task block   <id> <reason>                             mark task Blocked with reason
  task wait    <id> <waitingFor>                         flag task waiting on input
  task approve <id>                                      approve a task that requires operator approval
  task list                                              list tasks with approval and waiting state
  task inspect <id>                                      inspect one task in full
  task new     <title> <owner> <lane> [due] [true|false] create task, optional needsApproval flag
  project status   <id> <status>            set project status
  project progress <id> <0-100>             set project progress %
  agent  <id> <status> [focus]              update team member
  calendar add <title> <type> <date> <owner> [detail]
  memory add <title> <summary> [tags]       store memory entry
  log <title> [detail]                      append activity entry

Environment:
  NEXUS_API   API base URL (default: http://localhost:3001)

Tip: run 'nexus status' first each session to orient without reading raw JSON.
EOF
    ;;

esac
