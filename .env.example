# Sentinel Nexus — environment configuration
# Copy to .env and adjust as needed.

# ── API server ──────────────────────────────────────────────────────
NEXUS_API_PORT=3001
NODE_ENV=development

# Override the full API base URL if the server runs on a non-default port/host.
# Leave blank — Next.js reads NEXUS_API_PORT and proxies automatically.
# NEXUS_API_URL=http://localhost:3001

# ── Database ────────────────────────────────────────────────────────
# Drivers: sqlite (recommended) | file-json (legacy fallback)
NEXUS_DB_DRIVER=sqlite
NEXUS_DB_DIR=~/.openclaw/data/nexus
NEXUS_DB_SCHEMA_PATH=./nexus.schema.sql
NEXUS_WORKSPACE_DIR=~/.openclaw/workspace

# Postgres (future — not wired yet):
# NEXUS_DB_DRIVER=postgres
# NEXUS_DB_URL=postgres://user:password@localhost:5432/nexus
