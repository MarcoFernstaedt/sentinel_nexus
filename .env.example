# Sentinel Nexus API
NEXUS_API_PORT=4001
NODE_ENV=development

# Optional frontend override. Leave blank for same-origin API calls.
# VITE_API_BASE_URL=http://localhost:4001

# Nexus DB boundary
# Default path is Nexus-owned and separate from other OpenClaw/runtime storage.
NEXUS_DB_DRIVER=file-json
NEXUS_DB_DIR=~/.openclaw/data/nexus
NEXUS_DB_SCHEMA_PATH=./nexus.schema.sql

# Future database runtime (not active until host/db setup exists)
# NEXUS_DB_DRIVER=sqlite
# NEXUS_DB_URL=file:~/.openclaw/data/nexus/nexus.sqlite
# NEXUS_DB_DRIVER=postgres
# NEXUS_DB_URL=postgres://user:password@localhost:5432/nexus
