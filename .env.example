# Sentinel Nexus API
NEXUS_API_PORT=3001
NODE_ENV=development

# Safe-by-default local bind. Only change to 0.0.0.0 when you intentionally
# expose Nexus to another machine or put it behind a reverse proxy/firewall.
NEXUS_API_HOST=127.0.0.1
NEXUS_WEB_HOST=127.0.0.1

# Optional frontend override. Leave blank for same-origin API calls.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional CORS allow-list for browser clients hitting the API directly from a
# different origin. Comma-separated origins only, no paths.
# NEXUS_ALLOWED_ORIGINS=http://localhost:3000,https://nexus.example.com

# Nexus DB boundary
# Default path is Nexus-owned and separate from other OpenClaw/runtime storage.
NEXUS_DB_DRIVER=file-json
NEXUS_DB_DIR=~/.openclaw/data/nexus
NEXUS_DB_SCHEMA_PATH=./nexus.schema.sql
NEXUS_WORKSPACE_DIR=~/.openclaw/workspace

# Future database runtime (not active until host/db setup exists)
# NEXUS_DB_DRIVER=sqlite
# NEXUS_DB_URL=file:~/.openclaw/data/nexus/nexus.sqlite
# NEXUS_DB_DRIVER=postgres
# NEXUS_DB_URL=postgres://user:password@localhost:5432/nexus
