{
  "name": "sentinel_nexus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "next dev --port 3000",
    "dev:api": "bash -lc 'npm run build:api >/dev/null && if [ -f .env ]; then exec node --env-file=.env dist-server/index.js; else exec node --env-file=.env.example dist-server/index.js; fi'",
    "build": "next build",
    "build:api": "tsc -p server/tsconfig.json",
    "build:all": "npm run build && npm run build:api",
    "test": "vitest run server/__tests__",
    "test:watch": "vitest server/__tests__",
    "lint": "next lint",
    "start": "node scripts/start.mjs",
    "start:web": "next start --hostname 0.0.0.0 --port 3000",
    "start:api": "node --env-file-if-exists=.env --env-file-if-exists=.env.example dist-server/index.js"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.0"
  }
}
